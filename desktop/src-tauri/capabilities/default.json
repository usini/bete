{
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:47822/*", "http://localhost:47822/*"]
  },
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    "allow-check-web-update",
    "allow-get-lan-url",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    }
  ]
}
